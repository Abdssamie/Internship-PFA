= Sécurité et Prévention des Risques

// GHS pictogram helper — renders one SVG icon at 30pt
#let ghs(code) = image(
  "../../GHS_Pictogrammes/" + code + ".svg",
  width: 30pt,
)

// Inline row of icons with a small gap
#let icons(..codes) = {
  for c in codes.pos() { box(ghs(c)); h(3pt) }
}

#table(
  columns: (1.8fr, auto, 2fr, 2fr),
  stroke: 0.5pt,
  fill: none,
  inset: (x: 8pt, y: 10pt),
  align: (left, center, left, left),

  [*Produit chimique*], [*Pictogramme(s) GHS*], [*Mentions de danger*], [*Conseils de prudence*],

  // Réactif coloré
  [Réactif coloré (3) \ (Aminobenzène sulfonamide + N-(1-naphthyl)ethylenediamine + $"H"_3"PO"_4$)],
  [#icons("GHS05", "GHS07")],
  [Provoque des brûlures de la peau et des lésions oculaires graves. Peut irriter les voies respiratoires.],
  [Porter des gants de protection, des vêtements de protection et un équipement de protection des yeux. Éviter de respirer les vapeurs. En cas de contact oculaire, rincer avec précaution à l'eau pendant plusieurs minutes et appeler immédiatement un médecin.],

  // Nitrite de sodium
  [Nitrite de sodium \ $"NaNO"_2$ \ (~100 mg/L N)],
  [#icons("GHS03", "GHS07", "GHS09")],
  [Peut aggraver un incendie (comburant). Toxique en cas d'ingestion. Très toxique pour les organismes aquatiques.],
  [Tenir à l'écart de la chaleur et des matières combustibles. Éviter le rejet dans l'environnement. Se laver les mains soigneusement après manipulation.],

  // Permanganate de potassium
  [Permanganate de potassium \ $"KMnO"_4$ \ (~0,01 mol/L)],
  [#icons("GHS03", "GHS05", "GHS08", "GHS09")],
  [Peut aggraver un incendie (comburant). Provoque de graves brûlures de la peau. Susceptible de nuire à la fertilité ou au fœtus. Très toxique pour la vie aquatique.],
  [Porter des gants et des lunettes de protection. Éviter tout contact pendant la grossesse. Éviter le rejet dans l'environnement.],

  // Acide sulfurique
  [Acide sulfurique \ $"H"_2"SO"_4$ \ (~2,5 mol/L)],
  [#icons("GHS05")],
  [Provoque de graves brûlures de la peau et des lésions oculaires graves.],
  [Porter des gants de protection et un équipement de protection des yeux. Ne pas respirer les vapeurs. En cas de contact cutané, rincer abondamment à l'eau.],
)

