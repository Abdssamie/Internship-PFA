//  1. SÉCURITÉ ET PRÉVENTION DES RISQUES
// ════════════════════════════════════════════════════════════

= Sécurité et Prévention des Risques

// GHS pictogram helper — renders one SVG icon at 30pt
#let ghs(code) = image(
  "../../GHS_Pictogrammes/" + code + ".svg",
  width: 30pt,
)

// Inline row of icons with a small gap
#let icons(..codes) = {
  for c in codes.pos() { box(ghs(c)); h(3pt) }
}

#table(
  columns: (1.8fr, auto, 2fr, 2fr),
  stroke: 0.5pt,
  fill: none,
  inset: (x: 8pt, y: 10pt),
  align: (left, center, left, left),

  [*Produit chimique*], [*Pictogramme(s) GHS*], [*Mentions de danger*], [*Conseils de prudence*],

  // Acide chlorhydrique
  [Acide chlorhydrique \ $"HCl"$ \ (solution à 10% V/V)],
  [#icons("GHS05", "GHS07")],
  [Provoque de graves brûlures de la peau et des lésions oculaires graves. Peut irriter les voies respiratoires.],
  [Porter des gants de protection, des vêtements de protection et un équipement de protection des yeux. Éviter de respirer les vapeurs. En cas de contact, rincer abondamment à l'eau.],

  // Chlorure de baryum dihydraté
  [Chlorure de baryum \ $"BaCl"_2 · 2"H"_2"O"$ \ (solution stabilisée à 10% m/V)],
  [#icons("GHS07")],
  [Toxique en cas d'ingestion. Nocif par inhalation.],
  [Se laver les mains soigneusement après manipulation. Ne pas manger, boire ou fumer en manipulant ce produit. Éviter de respirer les poussières/brouillards.],

  // Sulfate de sodium
  [Sulfate de sodium anhydre \ $"Na"_2"SO"_4$],
  [—],
  [Non classé comme dangereux selon le règlement CLP.],
  [Manipuler conformément aux bonnes pratiques d'hygiène industrielle. Éviter la formation de poussières.],

  // Agent stabilisant
  [Tween 20 ou PVP \ (Polyvinylpyrrolidone)],
  [—],
  [Non classé comme dangereux selon le règlement CLP.],
  [Porter un équipement de protection individuel standard. Éviter le contact direct avec les yeux.]
)

