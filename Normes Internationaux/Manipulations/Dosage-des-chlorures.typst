//  ② SÉCURITÉ ET PRÉVENTION DES RISQUES
// ════════════════════════════════════════════════════════════

= Sécurité et Prévention des Risques

// ── 2.1 Pictogrammes et mentions de danger ───────────────────
== Pictogrammes et Mentions de Danger Réglementaires

// GHS pictogram helper — renders one SVG icon at 30pt
#let ghs(code) = image(
  "../GHS_Pictogrammes/" + code + ".svg",
  width: 30pt,
)

// Inline row of icons with a small gap
#let icons(..codes) = {
  for c in codes.pos() { box(ghs(c)); h(3pt) }
}

#show table.cell: set text(hyphenate: false)
#table(
  columns: (1.8fr, auto, 2fr, 2fr),
  stroke: 0.5pt,
  fill: none,
  inset: (x: 8pt, y: 10pt),
  align: (left, center, left, left),

  [*Produit chimique*], [*Pictogramme(s) GHS*], [*Mentions de danger*], [*Conseils de prudence*],

  // ── AgNO₃ : GHS03 · GHS05 · GHS09
  [Nitrate d'argent \ $"AgNO"_3$],
  [#icons("GHS03", "GHS05", "GHS09")],
  [Comburant, très corrosif pour la peau et nocif pour l'environnement.],
  [Porter des gants/lunettes et éviter tout rejet à l'évier.],

  // ── K₂CrO₄ : GHS07 · GHS08 · GHS09
  [Chromate de potassium \ $"K"_2"CrO"_4$],
  [#icons("GHS07", "GHS08", "GHS09")],
  [Toxique, cancérogène avéré et dangereux pour l'environnement.],
  [Manipuler strictement sous hotte avec gants et lunettes.],

  // ── HNO₃ 0,1 mol/L : GHS05
  [Acide nitrique $"HNO"_3$ \ $0","1 "mol/L"$],
  [#icons("GHS05")],
  [Corrosif pour les métaux et la peau à cette concentration.],
  [Éviter de respirer les vapeurs et porter des gants/lunettes.],

  // ── NaOH 0,1 mol/L : GHS05
  [Hydroxyde de sodium $"NaOH"$ \ $0","1 "mol/L"$],
  [#icons("GHS05")],
  [Faiblement corrosif (attaque les métaux et irrite la peau).],
  [Conserver dans son flacon d'origine et rincer à l'eau en cas de contact.],
)


