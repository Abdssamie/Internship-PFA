//  1. SÉCURITÉ ET PRÉVENTION DES RISQUES
// ════════════════════════════════════════════════════════════

= Sécurité et Prévention des Risques

// GHS pictogram helper — renders one SVG icon at 30pt
#let ghs(code) = image(
  "../../GHS_Pictogrammes/" + code + ".svg",
  width: 30pt,
)

// Inline row of icons with a small gap
#let icons(..codes) = {
  for c in codes.pos() { box(ghs(c)); h(3pt) }
}

#table(
  columns: (1.8fr, auto, 2fr, 2fr),
  stroke: 0.5pt,
  inset: (x: 8pt, y: 10pt),
  align: (left, center, left, left),

  [*Produit chimique*], [*Pictogramme(s) GHS*], [*Mentions de danger*], [*Conseils de prudence*],

  // Permanganate de potassium
  [Permanganate de potassium (1) et (2) \ $"KMnO"_4$ \ (~0,02 mol/L et ~0,002 mol/L)],
  [#icons("GHS03", "GHS07", "GHS08", "GHS09")],
  [Comburant et nocif. Suspecté de nuire à la fertilité ou au fœtus. Très toxique pour les organismes aquatiques.],
  [Conserver à l'écart de la chaleur et des matières combustibles. Porter des gants et des lunettes de protection. Éviter le rejet dans l'environnement.],

  // Acide sulfurique
  [Acide sulfurique (5) et (6) \ $"H"_2"SO"_4$ \ (7,5 mol/L et 2 mol/L)],
  [#icons("GHS05")],
  [Corrosif (provoque de graves brûlures de la peau et des lésions oculaires). Corrosif pour les métaux.],
  [Porter des gants de protection, des vêtements de protection et un équipement de protection des yeux. Ne jamais verser d'eau dans l'acide.],

  // Oxalate de sodium
  [Oxalate de sodium (3) et (4) \ $"Na"_2"C"_2"O"_4$ \ (0,05 mol/L et 0,005 mol/L)],
  [#icons("GHS07")],
  [Nocif par contact cutané et par ingestion. Provoque une sévère irritation des yeux.],
  [Porter des gants de protection et se laver les mains soigneusement après manipulation.],
)

